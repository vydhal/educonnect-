generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(cuid())
  email                 String            @unique
  password              String
  name                  String
  role                  String            @default("ALUNO")
  avatar                String?
  bio                   String?
  school                String?
  verified              Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  address               String?
  inep                  String?
  phone                 String?
  zone                  String?
  schoolId              String?
  schoolType            String?
  badgesGiven           Badge[]           @relation("badgeGiver")
  badgesReceived        Badge[]           @relation("badgeReceiver")
  comments              Comment[]
  receivedFriendships   Friendship[]      @relation("receivedFriendships")
  sentFriendships       Friendship[]      @relation("sentFriendships")
  likes                 Like[]
  moderationItems       ModerationItem[]
  notificationsReceived Notification[]    @relation("recipientNotifications")
  notificationsSent     Notification[]    @relation("senderNotifications")
  posts                 Post[]
  profileViews          ProfileView[]     @relation("profileOwner")
  viewsObserved         ProfileView[]     @relation("viewer")
  projects              Project[]
  projectComments       ProjectComment[]
  projectFavorites      ProjectFavorite[]
  projectLikes          ProjectLike[]
  testimonialsReceived  Testimonial[]     @relation("testimonialReceiver")
  testimonialsSent      Testimonial[]     @relation("testimonialSender")
  worksAt               User?             @relation("SchoolTeachers", fields: [schoolId], references: [id])
  teachers              User[]            @relation("SchoolTeachers")
  
  // Many-to-Many relationship for multiple school assignments (e.g. Teachers working in multiple units)
  memberOfSchools       User[]            @relation("UserSchoolAssociation")
  schoolMembers         User[]            @relation("UserSchoolAssociation")

  following             UserFollow[]      @relation("follower")
  followers             UserFollow[]      @relation("following")
  postsInSchool        Post[]            @relation("SchoolPosts")
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  recipientId String
  senderId    String?
  relatedId   String?
  content     String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  recipient   User     @relation("recipientNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  sender      User?    @relation("senderNotifications", fields: [senderId], references: [id])

  @@index([recipientId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Friendship {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receiver   User     @relation("receivedFriendships", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("sentFriendships", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Post {
  id         String          @id @default(cuid())
  content    String
  image      String?
  authorId   String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  images     String[]
  tags       String[]        @default([])
  comments   Comment[]
  likes      Like[]
  moderation ModerationItem?
  author     User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  schoolId   String?
  school     User?           @relation("SchoolPosts", fields: [schoolId], references: [id])
}

model WeeklyEvent {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  type      String   @default("LIKE")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model ModerationItem {
  id          String   @id @default(cuid())
  postId      String   @unique
  moderatorId String?
  status      String   @default("PENDENTE")
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  moderator   User?    @relation(fields: [moderatorId], references: [id])
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Project {
  id          String            @id @default(cuid())
  title       String
  description String
  image       String?
  authorId    String
  category    String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  attachments String[]
  componente  String?
  content     String?
  etapa       String?
  images      String[]
  author      User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    ProjectComment[]
  favorites   ProjectFavorite[]
  likes       ProjectLike[]
}

model ProjectLike {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProjectFavorite {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProjectComment {
  id        String   @id @default(cuid())
  content   String
  projectId String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model BadgeType {
  id          String   @id @default(cuid())
  name        String   @unique
  icon        String
  description String?
  color       String   @default("#7C3AED")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  badges      Badge[]
}

model Badge {
  id          String    @id @default(cuid())
  badgeTypeId String
  giverId     String
  receiverId  String
  createdAt   DateTime  @default(now())
  badgeType   BadgeType @relation(fields: [badgeTypeId], references: [id], onDelete: Cascade)
  giver       User      @relation("badgeGiver", fields: [giverId], references: [id], onDelete: Cascade)
  receiver    User      @relation("badgeReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([giverId, receiverId, badgeTypeId])
}

model ProfileView {
  id        String   @id @default(cuid())
  viewerId  String
  profileId String
  createdAt DateTime @default(now())
  owner     User     @relation("profileOwner", fields: [profileId], references: [id], onDelete: Cascade)
  viewer    User     @relation("viewer", fields: [viewerId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Testimonial {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  receiverId String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receiver   User     @relation("testimonialReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("testimonialSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([receiverId])
}

model SupportItem {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String
  link      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
