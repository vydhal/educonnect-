# 🚀 EduConnect Backend - Environment Variables Example
# Duplicate this file as .env and fill in your actual values.

# 🗄️ Database Connection
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/educonnect_db?schema=public"

# 🔐 Security
JWT_SECRET="sua-chave-secreta-super-protegida"
SOCIAL_SSO_SECRET="chave-de-assinatura-jwt-para-sso-educampina"

# 🌐 Server Configuration
PORT=5001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3001"

# 🛠️ Development Tools
ALLOW_RESEED=true

# 🔌 Portal EduCampina Integration
PORTAL_API_URL="https://api.portaleducampina.com.br"
PORTAL_API_KEY="CHAVE_API_GERADA_NO_PORTAL_ADMIN"

# 🔗 EduConnect SSO Configuration
EDUCONNECT_API_KEY="GK8ALtde1m4cnOhjr9ukpNxWTIVS6CRa"
EDUCONNECT_URL="https://educonnect.portaleducampina.com.br"